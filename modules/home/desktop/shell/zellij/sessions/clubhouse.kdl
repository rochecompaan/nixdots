layout {
  default_tab_template {
    pane size=1 borderless=true {
      plugin location="zellij:tab-bar"
    }
    children
  }
  tab name="infra" cwd="/home/roche/projects/clubhouse/clubhouse_infra/" {
    pane split_direction="vertical" {
      pane cwd="/home/roche/projects/clubhouse/clubhouse_infra/" command="@zellijDirenvExec@" { args "nvim" }
      pane stacked=true {
        pane cwd="/home/roche/projects/clubhouse/clubhouse_infra/" expanded=true command="@zellijDirenvExec@" {
          args "pi" "-c"
        }
        pane cwd="/home/roche/projects/clubhouse/clubhouse_infra/" command="@zellijDirenvExec@"
      }
    }
  }
  tab name="server" cwd="/home/roche/projects/clubhouse/clubhouse_server/" {
    pane split_direction="vertical" {
      pane cwd="/home/roche/projects/clubhouse/clubhouse_server/" command="@zellijDirenvExec@" { args "nvim" }
      pane stacked=true {
        pane cwd="/home/roche/projects/clubhouse/clubhouse_server/" expanded=true command="@zellijDirenvExec@" {
          args "pi" "-c"
        }
        pane cwd="/home/roche/projects/clubhouse/clubhouse_server/" command="@zellijDirenvExec@"
      }
    }
  }
}
