layout {
  default_tab_template {
    pane size=1 borderless=true {
      plugin location="zellij:tab-bar"
    }
    children
  }
  tab name="infra" cwd="/home/roche/projects/clubhouse/clubhouse_infra/" {
    pane split_direction="vertical" {
      pane cwd="/home/roche/projects/clubhouse/clubhouse_infra/" command="nvim"
      pane stacked=true {
        pane cwd="/home/roche/projects/clubhouse/clubhouse_infra/" expanded=true command="pi"
        pane cwd="/home/roche/projects/clubhouse/clubhouse_infra/"
      }
    }
  }
  tab name="server" cwd="/home/roche/projects/clubhouse/clubhouse_server/" {
    pane split_direction="vertical" {
      pane cwd="/home/roche/projects/clubhouse/clubhouse_server/" command="nvim"
      pane stacked=true {
        pane cwd="/home/roche/projects/clubhouse/clubhouse_server/" expanded=true command="pi"
        pane cwd="/home/roche/projects/clubhouse/clubhouse_server/"
      }
    }
  }
}
