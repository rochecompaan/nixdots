layout {
  default_tab_template {
    pane size=1 borderless=true {
      plugin location="zellij:tab-bar"
    }
    pane split_direction="vertical" {
      pane cwd="/home/roche/projects/clubhouse" command="nvim"
      pane stacked=true {
        pane cwd="/home/roche/projects/clubhouse" expanded=true command="jailed-pi"
        pane cwd="/home/roche/projects/clubhouse"
      }
    }
  }
  tab name="clubhouse"
}
