layout {
  default_tab_template {
    pane size=1 borderless=true {
      plugin location="zellij:tab-bar"
    }
    pane split_direction="vertical" {
      pane cwd="/home/roche/projects/patchmill" command="nvim"
      pane stacked=true {
        pane cwd="/home/roche/projects/patchmill" expanded=true command="pi" {
          args "-c"
        }
        pane cwd="/home/roche/projects/patchmill"
      }
    }
  }
  tab name="patchmill"
}
