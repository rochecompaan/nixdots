layout {
  default_tab_template {
    pane size=1 borderless=true {
      plugin location="zellij:tab-bar"
    }
    pane split_direction="vertical" {
      pane cwd="/home/roche/projects/scaf" command="nvim"
      pane stacked=true {
        pane cwd="/home/roche/projects/scaf" expanded=true command="pi"
        pane cwd="/home/roche/projects/scaf"
      }
    }
  }
  tab name="scaf"
}
