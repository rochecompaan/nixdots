layout {
  default_tab_template {
    pane size=1 borderless=true {
      plugin location="zellij:tab-bar"
    }
    pane split_direction="vertical" {
      pane cwd="/home/roche/projects/siyavula.deploy" command="nvim"
      pane stacked=true {
        pane cwd="/home/roche/projects/siyavula.deploy" expanded=true command="jailed-pi"
        pane cwd="/home/roche/projects/siyavula.deploy"
      }
    }
  }
  tab name="siyavula.deploy"
}
